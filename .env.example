# =============================================================================
# Lumen server — environment configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit a real .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Stellar network
# -----------------------------------------------------------------------------
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# -----------------------------------------------------------------------------
# Signer provider
# -----------------------------------------------------------------------------
# Controls how the co-signer and fee-payer private keys are accessed.
#
#   env     (default) — raw Stellar secret keys loaded from the variables below.
#                       Safe for local development and testnet only.
#                       ⚠  These keys are CUSTODIAL: they can approve user txs
#                       and spend XLM.  Do NOT use raw secrets in production.
#
#   awskms  (recommended for production) — private keys never leave AWS KMS /
#           CloudHSM.  Set the KMS_* variables below and leave COSIGNER_SECRET
#           and FEE_PAYER_SECRET unset.
#           Requires @aws-sdk/client-kms and appropriate IAM permissions.
#           See docs/production-key-management.md.
#
SIGNER_PROVIDER=env

# -----------------------------------------------------------------------------
# Dev / testnet secrets (SIGNER_PROVIDER=env only)
# ⚠  Raw secret keys in environment variables are NOT suitable for production.
#    A stolen COSIGNER_SECRET lets an attacker co-sign arbitrary user txs.
#    A stolen FEE_PAYER_SECRET drains your XLM fee reserve.
#    Use SIGNER_PROVIDER=awskms in production instead.
# -----------------------------------------------------------------------------
COSIGNER_SECRET=S...          # Server co-signer secret key  (testnet only)
FEE_PAYER_SECRET=S...         # Fee sponsor secret key        (testnet only)

# -----------------------------------------------------------------------------
# AWS KMS signers (SIGNER_PROVIDER=awskms only)
# These are IGNORED when SIGNER_PROVIDER=env.
# -----------------------------------------------------------------------------
# KMS_COSIGNER_KEY_ID=arn:aws:kms:<region>:<account>:key/<uuid>
# KMS_FEE_PAYER_KEY_ID=arn:aws:kms:<region>:<account>:key/<uuid>
# KMS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Anchor (Phase 1)
# -----------------------------------------------------------------------------
ANCHOR_URL=https://testanchor.stellar.org
ANCHOR_AUTH_SECRET=S...

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
